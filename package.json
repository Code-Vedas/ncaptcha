{
  "name": "ncaptcha-api",
  "version": "2.0.0",
  "description": "Modern captcha generator and verifier for Node.js APIs",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist coverage .nyc_output",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "coverage": "npm run build && c8 --check-coverage --lines 90 --functions 90 --branches 85 --statements 90 --reporter=text --reporter=lcov node --test dist/test/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niteshpurohit/ncaptcha.git"
  },
  "keywords": [
    "captcha",
    "nodejs",
    "security",
    "api"
  ],
  "author": "Nitesh Purohit <nitesh.purohit.it@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/niteshpurohit/ncaptcha/issues"
  },
  "homepage": "https://github.com/niteshpurohit/ncaptcha#readme",
  "dependencies": {
    "canvas": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "c8": "^10.1.3",
    "typescript": "^5.9.3"
  }
}
